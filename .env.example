# Aden Hive - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env with real credentials

# ============================================================
# LLM Provider API Keys
# ============================================================

# Primary provider (recommended for production)
ANTHROPIC_API_KEY=sk-ant-...

# Alternative providers (optional - enable as needed)
# OPENAI_API_KEY=sk-...
# MINIMAX_API_KEY=...
# GEMINI_API_KEY=...
# GOOGLE_API_KEY=...
# GROQ_API_KEY=...
# CEREBRAS_API_KEY=...
# OPENROUTER_API_KEY=...
# MISTRAL_API_KEY=...
# TOGETHER_API_KEY=...
# DEEPSEEK_API_KEY=...

# ============================================================
# Hive Configuration
# ============================================================

PYTHONPATH=/app/core:/app/exports
HIVE_ENV=production
PORT=8000

# ============================================================
# Optional: Service-Specific Keys
# ============================================================

# ElevenLabs (for CineStory voice generation)
# ELEVENLABS_API_KEY=...

# Other service integrations
# YOUTUBE_API_KEY=...
# TIKTOK_API_KEY=...
